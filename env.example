# 复制本文件为 .env 或在部署平台配置同名环境变量（不要提交含真实密码的 .env）

# ========== PostgreSQL（推荐生产）==========
# 必须是完整连接 URI，不能写成单词 "PostgreSQL"。
# 标准格式：
#   postgresql://用户名:密码@主机:5432/数据库名
# 若密码含特殊字符，需做 URL 编码（如 @ -> %40）。
# Railway / Heroku 等若提供 postgres:// 开头，本应用会自动转为 postgresql+psycopg2://，无需改平台变量。
#
# 示例（请替换为真实值）：
# DATABASE_URL=postgresql://cbti:yourpassword@db.example.com:5432/cbti

DATABASE_URL=

# ========== 应用密钥（必填生产）==========
SECRET_KEY=

# ========== 管理后台 ==========
ADMIN_PASSWORD=
# LEGACY_ADMIN_PASSWORD=

# HTTPS 下建议开启（Cookie 仅 Secure 传输）
# SESSION_COOKIE_SECURE=1

# 可选：连接池（仅 PostgreSQL 分支生效）
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40
# DB_POOL_RECYCLE=3600
